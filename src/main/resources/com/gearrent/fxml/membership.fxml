<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gearrent.controller.MembershipController"
      spacing="16" styleClass="view-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Membership and Pricing Configuration" styleClass="page-title"/>

    <Label text="Membership Levels" styleClass="section-title"/>
    <TableView fx:id="tblMem" prefHeight="180">
        <columns>
            <TableColumn fx:id="colLevel"    text="Level"         prefWidth="120"/>
            <TableColumn fx:id="colDiscount" text="Discount %"    prefWidth="120"/>
            <TableColumn fx:id="colLimit"    text="Deposit Limit" prefWidth="160"/>
        </columns>
    </TableView>

    <HBox spacing="16">
        <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Edit Membership Level" styleClass="section-title"/>
            <Label fx:id="lblLevel" text="-- select a row above --" styleClass="info-label"/>
            <Label text="Discount Percentage (0-100)"/>
            <TextField fx:id="txtDiscount" styleClass="form-field" promptText="e.g. 5.0"/>
            <Label text="Deposit Limit (LKR)"/>
            <TextField fx:id="txtLimit" styleClass="form-field" promptText="e.g. 750000"/>
            <Button text="Save Membership" onAction="#handleSave"
                    styleClass="btn-primary" maxWidth="Infinity"/>
        </VBox>

        <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Pricing Rules" styleClass="section-title"/>
            <Label text="Long Rental Minimum Days"/>
            <TextField fx:id="txtMinDays" styleClass="form-field" promptText="e.g. 7"/>
            <Label text="Long Rental Discount %"/>
            <TextField fx:id="txtLongDiscount" styleClass="form-field" promptText="e.g. 10.0"/>
            <Label text="Global Late Fee per Day (LKR)"/>
            <TextField fx:id="txtLateFee" styleClass="form-field" promptText="e.g. 500.0"/>
            <Button text="Save Pricing Rules" onAction="#handleSavePricing"
                    styleClass="btn-primary" maxWidth="Infinity"/>
            <Label fx:id="lblPricingStatus" styleClass="info-label" wrapText="true"/>
        </VBox>
    </HBox>
</VBox>