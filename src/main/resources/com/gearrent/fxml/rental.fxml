<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gearrent.controller.RentalController"
      spacing="12" styleClass="view-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Rentals" styleClass="page-title"/>

    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
        <Label text="Status:"/>
        <ComboBox fx:id="cmbFilterStatus" prefWidth="120"/>
        <Label text="From:"/>
        <DatePicker fx:id="dpFilterFrom" prefWidth="130"/>
        <Label text="To:"/>
        <DatePicker fx:id="dpFilterTo" prefWidth="130"/>
        <Button text="Filter" onAction="#handleFilter" styleClass="btn-secondary"/>
        <Button text="Cancel Rental" onAction="#handleCancel" styleClass="btn-danger"/>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Rentals Table -->
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <TableView fx:id="tblRentals" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colId"      text="#"         prefWidth="45"/>
                    <TableColumn fx:id="colEquip"   text="Equipment" prefWidth="170"/>
                    <TableColumn fx:id="colCust"    text="Customer"  prefWidth="120"/>
                    <TableColumn fx:id="colBranch"  text="Branch"    prefWidth="100"/>
                    <TableColumn fx:id="colStart"   text="Start"     prefWidth="90"/>
                    <TableColumn fx:id="colEnd"     text="End"       prefWidth="90"/>
                    <TableColumn fx:id="colFinal"   text="Payable"   prefWidth="100"/>
                    <TableColumn fx:id="colPayment" text="Payment"   prefWidth="90"/>
                    <TableColumn fx:id="colStatus"  text="Status"    prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>

        <!-- New Rental Form -->
        <ScrollPane fitToWidth="true" minWidth="300" maxWidth="320">
            <VBox styleClass="card" spacing="10">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="New Rental" styleClass="section-title"/>

                <Label text="Branch *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbBranch" maxWidth="Infinity"
                          promptText="-- Select Branch --"/>

                <Label text="Start Date *" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="dpStart" maxWidth="Infinity"/>

                <Label text="End Date * (max 30 days)" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="dpEnd" maxWidth="Infinity"/>

                <Label text="Available Equipment *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbEquipment" maxWidth="Infinity"
                          promptText="-- Select Equipment --"/>

                <Label text="Customer *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbCustomer" maxWidth="Infinity"
                          promptText="-- Select Customer --"/>

                <Label text="Payment Status *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbPayment" maxWidth="Infinity"/>

                <VBox spacing="6"
                      style="-fx-background-color: #EFF6FF; -fx-border-color: #BFDBFE; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                    <Label text="Cost Preview"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1E40AF;"/>
                    <HBox spacing="0">
                        <Label text="Rental Amount:" minWidth="140"
                               style="-fx-text-fill: #334155; -fx-font-size: 11px;"/>
                        <Label fx:id="lblRentalAmt" text="--"
                               style="-fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                    </HBox>
                    <HBox spacing="0">
                        <Label text="Long Discount:" minWidth="140"
                               style="-fx-text-fill: #16A34A; -fx-font-size: 11px;"/>
                        <Label fx:id="lblLongDisc" text="--"
                               style="-fx-font-weight: bold; -fx-text-fill: #16A34A;"/>
                    </HBox>
                    <HBox spacing="0">
                        <Label text="Member Discount:" minWidth="140"
                               style="-fx-text-fill: #16A34A; -fx-font-size: 11px;"/>
                        <Label fx:id="lblMemDisc" text="--"
                               style="-fx-font-weight: bold; -fx-text-fill: #16A34A;"/>
                    </HBox>
                    <HBox spacing="0">
                        <Label text="Security Deposit:" minWidth="140"
                               style="-fx-text-fill: #334155; -fx-font-size: 11px;"/>
                        <Label fx:id="lblDeposit" text="--"
                               style="-fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                    </HBox>
                    <Separator/>
                    <HBox spacing="0">
                        <Label text="TOTAL PAYABLE:" minWidth="140"
                               style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1E3A8A;"/>
                        <Label fx:id="lblFinal" text="--"
                               style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2563EB;"/>
                    </HBox>
                </VBox>

                <Button text="Create Rental" onAction="#handleCreate"
                        maxWidth="Infinity" styleClass="btn-primary"/>
            </VBox>
        </ScrollPane>
    </HBox>
</VBox>