<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gearrent.controller.CustomerController"
      spacing="12" styleClass="view-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Customer Management" styleClass="page-title"/>

    <!-- Search Bar -->
    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
        <TextField fx:id="txtSearch"
                   promptText="Search by name, NIC, email..."
                   prefWidth="300"
                   style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>
        <Button text="Search" onAction="#handleSearch" styleClass="btn-secondary"/>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Table -->
        <VBox HBox.hgrow="ALWAYS" spacing="6">
            <TableView fx:id="tblCust" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"      text="#"          prefWidth="45"/>
                    <TableColumn fx:id="colName"    text="Name"       prefWidth="160"/>
                    <TableColumn fx:id="colNic"     text="NIC/Pass"   prefWidth="130"/>
                    <TableColumn fx:id="colContact" text="Contact"    prefWidth="110"/>
                    <TableColumn fx:id="colEmail"   text="Email"      prefWidth="160"/>
                    <TableColumn fx:id="colLevel"   text="Membership" prefWidth="90"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Form -->
        <VBox styleClass="card" spacing="10" minWidth="300" maxWidth="340">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Customer Details" styleClass="section-title"/>

            <Label text="Full Name *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtName"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <Label text="NIC / Passport *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtNic"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <Label text="Contact No *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtContact"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <Label text="Email" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtEmail"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <Label text="Address" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtAddress"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <Label text="Membership Level" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="cmbLevel" maxWidth="Infinity"/>

            <Label fx:id="lblDeposit" styleClass="info-label"
                   style="-fx-text-fill: #2563EB; -fx-font-size: 11px;"/>

            <HBox spacing="6">
                <Button text="Save"    onAction="#handleSave"
                        styleClass="btn-primary"   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Delete"  onAction="#handleDelete"
                        styleClass="btn-danger"    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="History" onAction="#handleViewHistory"
                        styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Clear"   onAction="#handleClear"
                        styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>