<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gearrent.controller.BranchController"
      spacing="16" styleClass="view-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Manage Branches" styleClass="page-title"/>
    <Label fx:id="lblStatus" styleClass="error-label"/>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <VBox HBox.hgrow="ALWAYS" spacing="6">
            <TableView fx:id="tblBranches" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colCode"    text="Code"    prefWidth="80"/>
                    <TableColumn fx:id="colName"    text="Name"    prefWidth="180"/>
                    <TableColumn fx:id="colAddress" text="Address" prefWidth="220"/>
                    <TableColumn fx:id="colContact" text="Contact" prefWidth="120"/>
                    <TableColumn fx:id="colActive"  text="Active"  prefWidth="70"/>
                </columns>
            </TableView>
        </VBox>

        <VBox styleClass="card" spacing="10" minWidth="320" maxWidth="360">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="Branch Details" styleClass="section-title"/>

            <Label text="Branch Code *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtCode" promptText="e.g. COL"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <Label text="Branch Name *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtName" promptText="e.g. Colombo Branch"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <Label text="Address" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtAddress" promptText="Street, City"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <Label text="Contact Number" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtContact" promptText="0xx-xxxxxxx"
                       style="-fx-background-color: white; -fx-text-fill: #0F172A; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10 7 10;"/>

            <CheckBox fx:id="chkActive" text="Active" selected="true"/>

            <HBox spacing="8">
                <Button text="Save"   onAction="#handleSave"   styleClass="btn-primary"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Delete" onAction="#handleDelete" styleClass="btn-danger"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Clear"  onAction="#handleClear"  styleClass="btn-secondary"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>