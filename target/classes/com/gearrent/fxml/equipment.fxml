<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gearrent.controller.EquipmentController"
      spacing="12" styleClass="view-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Equipment Management" styleClass="page-title"/>

    <!-- Filters -->
    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
        <Label text="Branch:"/>
        <ComboBox fx:id="cmbFilterBranch" prefWidth="140"/>
        <Label text="Category:"/>
        <ComboBox fx:id="cmbFilterCat" prefWidth="130"/>
        <Label text="Status:"/>
        <ComboBox fx:id="cmbFilterStatus" prefWidth="130"/>
        <Label text="Search:"/>
        <TextField fx:id="txtSearch" promptText="Brand / Model / ID" prefWidth="160"/>
        <Button text="🔍 Filter" onAction="#handleFilter" styleClass="btn-secondary"/>
    </HBox>

    <SplitPane dividerPositions="0.58" VBox.vgrow="ALWAYS">
        <!-- Table -->
        <VBox>
            <TableView fx:id="tblEq" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"       prefWidth="110"/>
                    <TableColumn fx:id="colCat"     text="Category" prefWidth="90"/>
                    <TableColumn fx:id="colBrand"   text="Brand"    prefWidth="90"/>
                    <TableColumn fx:id="colModel"   text="Model"    prefWidth="110"/>
                    <TableColumn fx:id="colYear"    text="Year"     prefWidth="55"/>
                    <TableColumn fx:id="colPrice"   text="Base/Day" prefWidth="100"/>
                    <TableColumn fx:id="colDeposit" text="Deposit"  prefWidth="100"/>
                    <TableColumn fx:id="colStatus"  text="Status"   prefWidth="100"/>
                    <TableColumn fx:id="colBranch"  text="Branch"   prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Form -->
        <ScrollPane fitToWidth="true">
        <VBox styleClass="card" spacing="10">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Equipment Details" styleClass="section-title"/>

            <Label text="Equipment ID *"/>
            <TextField fx:id="txtId" promptText="e.g. EQ-COL-009" styleClass="form-field"/>

            <Label text="Branch *"/>
            <ComboBox fx:id="cmbBranch" maxWidth="Infinity" styleClass="form-field"/>

            <Label text="Category *"/>
            <ComboBox fx:id="cmbCat" maxWidth="Infinity" styleClass="form-field"/>

            <Label text="Brand *"/>
            <TextField fx:id="txtBrand" promptText="e.g. Sony" styleClass="form-field"/>

            <Label text="Model *"/>
            <TextField fx:id="txtModel" promptText="e.g. A7 IV" styleClass="form-field"/>

            <Label text="Purchase Year *"/>
            <TextField fx:id="txtYear" styleClass="form-field"/>

            <Label text="Daily Base Price (LKR) *"/>
            <TextField fx:id="txtPrice" styleClass="form-field"/>

            <Label text="Security Deposit (LKR) *"/>
            <TextField fx:id="txtDeposit" styleClass="form-field"/>

            <Label text="Status"/>
            <ComboBox fx:id="cmbStatus" maxWidth="Infinity" styleClass="form-field"/>

            <Label fx:id="lblStatus" styleClass="error-label"/>

            <HBox spacing="8">
                <Button text="💾 Save"   onAction="#handleSave"   styleClass="btn-primary"   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="🗑 Delete" onAction="#handleDelete" styleClass="btn-danger"    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="✖ Clear"  onAction="#handleClear"  styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </VBox>
        </ScrollPane>
    </SplitPane>
</VBox>
