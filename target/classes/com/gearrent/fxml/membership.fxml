<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gearrent.controller.MembershipController"
      spacing="16" styleClass="view-root" maxWidth="700">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Membership Configuration" styleClass="page-title"/>

    <TableView fx:id="tblMem" prefHeight="200">
        <columns>
            <TableColumn fx:id="colLevel"    text="Level"           prefWidth="120"/>
            <TableColumn fx:id="colDiscount" text="Discount %"      prefWidth="120"/>
            <TableColumn fx:id="colLimit"    text="Deposit Limit"   prefWidth="160"/>
        </columns>
    </TableView>

    <VBox styleClass="card" spacing="10" maxWidth="400">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        <Label text="Edit Level" styleClass="section-title"/>
        <Label fx:id="lblLevel" text="— select a row —" styleClass="info-label"/>
        <Label text="Discount Percentage (0–100)"/>
        <TextField fx:id="txtDiscount" styleClass="form-field" promptText="e.g. 5.0"/>
        <Label text="Deposit Limit (LKR)"/>
        <TextField fx:id="txtLimit" styleClass="form-field" promptText="e.g. 750000"/>
        <Button text="💾 Save Changes" onAction="#handleSave" styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>
</VBox>
